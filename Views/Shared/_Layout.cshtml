<!DOCTYPE html>
<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - FarmaDual</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>
        body {
            background: #f4f7fb;
            color: #2e3a46;
        }

        .fd-navbar {
            background: linear-gradient(90deg, #ffffff 0%, #edf4ff 100%);
            border-bottom: 1px solid #dce8ff;
            box-shadow: 0 2px 10px rgba(31, 70, 144, 0.08);
        }

        .fd-navbar .navbar-brand {
            color: #1f4ea0 !important;
            font-weight: 700;
            letter-spacing: .3px;
        }

        .fd-navbar .nav-link {
            color: #34517a !important;
            font-weight: 500;
        }

        .fd-navbar .nav-link:hover {
            color: #1f4ea0 !important;
        }

        .fd-shell {
            background: #fff;
            border: 1px solid #e8eef8;
            border-radius: 14px;
            margin-top: 18px;
            padding: 18px;
            box-shadow: 0 6px 20px rgba(31, 78, 160, 0.06);
        }

        .fd-footer {
            color: #6f7f96;
            font-size: .92rem;
            margin-top: 18px;
        }
    </style>
</head>
<body>
    @* El bloque que consultaba la BD fue movido a acciones parciales en ProfileController.
       Usamos Html.Action para renderizar el fragmento de usuario en navbar y header. *@

    <nav class="navbar navbar-expand-sm navbar-toggleable-sm fd-navbar">
        <div class="container">
            @Html.ActionLink("FarmaDual", "Index", "Medicamentos", new { area = "" }, new { @class = "navbar-brand" })
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Alternar navegación" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">@Html.ActionLink("Medicamentos", "Index", "Medicamentos", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Facturas", "Index", "Facturas", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Tipos de medicamentos", "Index", "GenerosMedicamento", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Módulos", "Index", "ModulosMedicamento", new { area = "" }, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Impuestos", "Index", "Impuestos", new { area = "" }, new { @class = "nav-link" })</li>
                </ul>

                @{ var isAdmin = User?.IsInRole("Admin") == true; }
                @* Enlace al panel de administración visible solo para administradores *@
                <div class="d-none d-sm-block me-3">
                    @if (isAdmin)
                    {
                        <text>@Html.ActionLink("Panel admin", "Index", "Admin", new { area = "" }, new { @class = "btn btn-outline-secondary btn-sm" })</text>
                    }
                </div>

                @{ Html.RenderAction("UserNav", "Profile"); }
            </div>
        </div>
    </nav>

    <div class="container mt-3">
        <div class="fd-shell">
            <main class="fd-content">
                @RenderBody()
            </main>
        </div>

        <footer class="fd-footer">
            <p>&copy; @DateTime.Now.Year - FarmaDual</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    @if (IsSectionDefined("Scripts"))
    {
        @RenderSection("Scripts", required: false)
    }
    else
    {
        @RenderSection("scripts", required: false)
    }
</body>
</html>
