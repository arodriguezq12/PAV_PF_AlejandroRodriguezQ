@model string
@{
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var displayName = Html.Encode(Model ?? string.Empty);
    var isAdmin = User?.IsInRole("Admin") == true;
}

<ul class="navbar-nav">
    @if (isAuthenticated)
    {
        <li class="nav-item d-flex align-items-center me-2"><span class="navbar-text">@displayName</span></li>

        @* Enlace rápido al panel admin si tiene el rol *@
        if (isAdmin)
        {
            <li class="nav-item me-2">
                @Html.ActionLink("Admin", "Index", "Admin", null, new { @class = "btn btn-outline-secondary btn-sm" })
            </li>
        }

        <li class="nav-item">
            @using (Html.BeginForm("Logout", "Account", FormMethod.Post, new { @class = "d-inline" }))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary btn-sm">Cerrar sesión</button>
            }
        </li>
    }
    else
    {
        <li class="nav-item">@Html.ActionLink("Login", "Login", "Account", null, new { @class = "btn btn-outline-primary btn-sm" })</li>
        <li class="nav-item">@Html.ActionLink("Registro", "Register", "Account", null, new { @class = "btn btn-primary btn-sm" })</li>
    }
</ul>
