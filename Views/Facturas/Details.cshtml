@model PAV_PF_AlejandroRodriguezQ.Models.ViewModels.FacturaDetailsVM
@{ ViewBag.Title = "Detalle factura"; }

<h2 class="mt-4">Detalle factura</h2>

<div class="card mb-3"><div class="card-body">
    <div><strong>Número:</strong> @Model.Factura.NumeroFactura</div>
    <div><strong>Fecha:</strong> @Model.Factura.Fecha.ToString("dd/MM/yyyy HH:mm")</div>
    <div><strong>Identificación:</strong> @Model.Factura.IdentificacionUsuario</div>
    <div><strong>Exento:</strong> @(Model.Factura.EsExento ? "Sí" : "No")</div>
</div></div>

<h5>Líneas</h5>
<table class="table table-bordered table-sm">
    <thead><tr><th>Código</th><th>Medicamento</th><th>Cantidad</th><th>P/U</th><th>Subtotal</th></tr></thead>
    <tbody>
        @foreach (var d in Model.Detalles)
        {
            <tr><td>@d.MedicamentoCodigo</td><td>@(d.Medicamento != null ? d.Medicamento.Nombre : "-")</td><td>@d.Cantidad</td><td>@d.PrecioUnitario.ToString("N2")</td><td>@d.SubtotalLinea.ToString("N2")</td></tr>
        }
    </tbody>
</table>

<h5>Impuestos</h5>
<table class="table table-bordered table-sm">
    <thead><tr><th>Impuesto</th><th>%</th><th>Monto</th></tr></thead>
    <tbody>
        @foreach (var i in Model.Impuestos)
        {
            <tr><td>@(i.Impuesto != null ? i.Impuesto.Nombre : i.ImpuestoId.ToString())</td><td>@i.PorcentajeAplicado</td><td>@i.MontoImpuesto.ToString("N2")</td></tr>
        }
    </tbody>
</table>

<div><strong>Subtotal:</strong> @Model.Factura.Subtotal.ToString("N2")</div>
<div><strong>Total Impuestos:</strong> @Model.Factura.TotalImpuestos.ToString("N2")</div>
<div><strong>Total:</strong> @Model.Factura.Total.ToString("N2")</div>

<div class="mt-3">@Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-outline-secondary" })</div>
