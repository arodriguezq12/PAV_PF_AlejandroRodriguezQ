@model FarmaDual.Models.ViewModels.LoginVM
@{
    ViewBag.Title = "Login";
}

<div class="container mt-4" style="max-width: 520px;">
    <div class="card shadow-sm">
        <div class="card-body">

            <h3 class="mb-4">Iniciar sesión</h3>

            @using (Html.BeginForm("Login", "Account", new { returnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { id = "loginForm", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                <div class="mb-3">
                    @Html.LabelFor(m => m.Correo, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", type = "text", autocomplete = "username", spellcheck = "false" })
                    @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", autocomplete = "current-password" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="form-check mb-3">
                    @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", id = "RememberMe" })
                    <label class="form-check-label" for="RememberMe">Recordarme</label>
                </div>

                <button type="submit" class="btn btn-primary w-100">Entrar</button>
            }

            <div class="mt-3 text-center">
                @Html.ActionLink("No tengo cuenta → Registrarme", "Register", "Account", null, null)
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
