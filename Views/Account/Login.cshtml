@model FarmaDual.Models.ViewModels.LoginVM
@{
    ViewBag.Title = "Login";
}

<div class="container mt-4" style="max-width: 520px;">
    <div class="card shadow-sm">
        <div class="card-body">

            <h3 class="mb-4">Iniciar sesión</h3>

            @using (Html.BeginForm("Login", "Account", new { returnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { id = "loginForm", novalidate = "novalidate" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                @if (ViewBag.DebugMode == true)
                {
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                }

                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                @if (ViewBag.DebugMode == true)
                {
                    var trace = ViewBag.DebugLoginTrace as System.Collections.Generic.IEnumerable<string>;
                    <div class="alert alert-warning small" role="alert">
                        <strong>Debug Login Activo</strong>
                        <div>Tip: desactiva quitando <code>?debug=1</code> de la URL.</div>
                        <hr class="my-2" />
                        <ul class="mb-0 ps-3">
                            @foreach (var step in trace ?? System.Linq.Enumerable.Empty<string>())
                            {
                                <li>@step</li>
                            }
                        </ul>
                    </div>
                }

                <div class="mb-3">
                    @Html.LabelFor(m => m.Correo, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", type = "email", autocomplete = "username", spellcheck = "false" })
                    @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", autocomplete = "current-password" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="form-check mb-3">
                    @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", id = "RememberMe" })
                    <label class="form-check-label" for="RememberMe">Recordarme</label>
                </div>

                <button type="submit" id="btnEntrar" class="btn btn-primary w-100">
                    <span class="btn-text">Entrar</span>
                </button>
            }

            <div class="mt-3 text-center">
                @Html.ActionLink("No tengo cuenta → Registrarme", "Register", "Account")
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        (function () {
            var form = document.getElementById('loginForm');
            var button = document.getElementById('btnEntrar');
            var textNode = button ? button.querySelector('.btn-text') : null;

            if (!form || !button || !textNode) return;

            var debugMode = @((ViewBag.DebugMode == true).ToString().ToLowerInvariant());
            var correoInput = document.getElementById('Correo');

            var defaultText = 'Entrar';
            var loadingText = 'Validando...';

            function setButtonState(isLoading) {
                button.disabled = isLoading;
                textNode.textContent = isLoading ? loadingText : defaultText;
            }

            form.addEventListener('submit', function () {
                // 1) Si jQuery validate está activo y el form es inválido, NO bloquear el botón
                if (window.jQuery && jQuery(form).data('validator')) {
                    if (!jQuery(form).valid()) return;
                }

                if (correoInput && typeof correoInput.value === 'string') {
                    correoInput.value = correoInput.value.trim();
                }

                if (correoInput && typeof correoInput.value === 'string') {
                    correoInput.value = correoInput.value.trim();
                }

                if (debugMode) { console.log('[Login Debug] Submit detectado, enviando formulario.'); }
                setButtonState(true);
            });

            window.addEventListener('pageshow', function () {
                setButtonState(false);
            });
        })();
    </script>
}
