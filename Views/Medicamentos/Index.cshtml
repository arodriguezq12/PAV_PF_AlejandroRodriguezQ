@model IEnumerable<PAV_PF_AlejandroRodriguezQ.Models.Medicamento>
@{
    ViewBag.Title = "Medicamentos";
}

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
    <h2 class="mb-0">Medicamentos</h2>
    @Html.ActionLink("Nuevo medicamento", "Create", null, new { @class = "btn btn-primary" })
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>C&oacute;digo</th>
            <th>Nombre</th>
            <th>Precio</th>
            <th>M&oacute;dulo</th>
            <th>Tipo</th>
            <th>Activo</th>
            <th style="width: 240px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr class="@(item.Activo ? "" : "table-secondary")">
                <td>@item.MedicamentoCodigo</td>
                <td>@item.Nombre</td>
                <td>@item.Precio.ToString("N2")</td>
                <td>@(item.ModuloMedicamento != null ? item.ModuloMedicamento.Nombre : "-")</td>
                <td>@(item.GeneroMedicamento != null ? item.GeneroMedicamento.Nombre : "-")</td>
                <td>
                    @if (item.Activo)
                    {
                        <span class="badge bg-success">Sí</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </td>
                <td>
                    <div class="d-flex flex-wrap gap-1">
                        @Html.ActionLink("Editar", "Edit", new { id = item.MedicamentoCodigo }, new { @class = "btn btn-sm btn-outline-primary" })
                        @Html.ActionLink("Detalle", "Details", new { id = item.MedicamentoCodigo }, new { @class = "btn btn-sm btn-outline-info" })

                        @if (item.Activo)
                        {
                            using (Html.BeginForm("Deactivate", "Medicamentos", new { id = item.MedicamentoCodigo }, FormMethod.Post, new { @class = "d-inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Desea desactivar este medicamento?');">
                                    Desactivar
                                </button>
                            }
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
