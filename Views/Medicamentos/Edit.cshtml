@model PAV_PF_AlejandroRodriguezQ.Models.ViewModels.MedicamentoFormVM
@{
    ViewBag.Title = "Editar medicamento";
}

<h2 class="mt-4">Editar medicamento</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(m => m.MedicamentoCodigo)

    <div class="row g-3 mt-1">
        <div class="col-md-4">
            @Html.LabelFor(m => m.MedicamentoCodigo, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.MedicamentoCodigo, new { @class = "form-control", @readonly = "readonly" })
        </div>

        <div class="col-md-8">
            @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4">
            @Html.LabelFor(m => m.Precio, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Precio, new { @class = "form-control", type = "number", step = "0.01", min = "0" })
            @Html.ValidationMessageFor(m => m.Precio, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4">
            @Html.LabelFor(m => m.ModuloCodigo, new { @class = "form-label" })
            @Html.DropDownListFor(m => m.ModuloCodigo, (SelectList)ViewBag.ModuloCodigo, "-- Seleccione --", new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.ModuloCodigo, "", new { @class = "text-danger" })
        </div>

        <div class="col-md-4">
            @Html.LabelFor(m => m.GeneroId, new { @class = "form-label" })
            @Html.DropDownListFor(m => m.GeneroId, (SelectList)ViewBag.GeneroId, "-- Seleccione --", new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.GeneroId, "", new { @class = "text-danger" })
        </div>

        <div class="col-12">
            <div class="form-check">
                @Html.CheckBoxFor(m => m.Activo, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.Activo, new { @class = "form-check-label" })
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
        @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-outline-secondary" })
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
